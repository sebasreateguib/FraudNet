# Binario específico de Mac/Linux (sin extensión)
fraud_net/build/fraud_net

# Archivos de entorno IDE (VSCode, CLion, etc.)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ==========================================
# Datasets Gigantes (Kaggle)
# ==========================================
# Es importantísimo ignorar el dataset original porque pesa 150MB 
# y GitHub bloqueará el push si lo intentas subir.
*.csv
fraud_net/data/creditcard.csv

# ==========================================
